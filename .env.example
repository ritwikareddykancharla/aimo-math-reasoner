# ================================
# AIMO Math Reasoner — Environment
# ================================

# HuggingFace
HF_TOKEN=hf_your_token_here

# WandB
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=aimo3-grpo
WANDB_ENTITY=ritwikareddykancharla-n-a

# Kaggle
KAGGLE_USERNAME=ritwikareddykancharla
KAGGLE_KEY=your_kaggle_api_key_here
KAGGLE_DATASET_ID=ritwikareddykancharla/gpt-oss-120b-aimo3-finetuned

# GitHub
GITHUB_TOKEN=your_github_token_here

# AWS
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# Node IPs
NODE1_IP=172.31.104.85
NODE2_IP=172.31.101.45

# Ray
RAY_HEAD_PORT=6379
RAY_OBJECT_STORE_MEMORY=100000000000

# Training
ROUND=1
MODEL_ID=unsloth/gpt-oss-120b
HF_CACHE_DIR=~/.cache/huggingface
CHECKPOINT_DIR=~/checkpoints

# NCCL / EFA
FI_PROVIDER=efa
FI_EFA_USE_DEVICE_RDMA=1
FI_EFA_FORK_SAFE=1
RDMAV_FORK_SAFE=1
NCCL_SOCKET_IFNAME=enp71s0
NCCL_IB_DISABLE=0
NCCL_TIMEOUT=1800
